# Ritual Staking environment variables
# Copy this file to .env.local and fill in deployed addresses.

NEXT_PUBLIC_CHAIN_ID=1979
NEXT_PUBLIC_CHAIN_NAME=Ritual Chain
NEXT_PUBLIC_RPC_URL=https://rpc.ritualfoundation.org
NEXT_PUBLIC_EXPLORER_URL=https://explorer.ritualfoundation.org

# Get project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# SBT contract address.
NEXT_PUBLIC_SBT_ADDRESS=0xbeF776D31F0fb4F141e12443Eb0956F5fBd75398

# Deployed RitualLSTv2 contract address.
NEXT_PUBLIC_STAKING_POOL_ADDRESS=0x4A425149530451c8729038b0eed63dB5EE3bB3ce

# Deployed xRITUALv2 ERC20 token contract address.
NEXT_PUBLIC_XRITUAL_ADDRESS=0x657F74071239744BCa740A45AA3dE7dbC985D2f7

# RitualLSTv2 deployment block used by the leaderboard event scanner.
NEXT_PUBLIC_STAKING_POOL_DEPLOYMENT_BLOCK=27755348

# Branding.
NEXT_PUBLIC_PROTOCOL_NAME=Ritual Staking
NEXT_PUBLIC_TOKEN_SYMBOL=RITUAL
NEXT_PUBLIC_LST_SYMBOL=xRITUAL
NEXT_PUBLIC_SBT_NAME=Ritual Identity SBT
NEXT_PUBLIC_SBT_SYMBOL=rSBT

# Supabase project used by the leaderboard API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only maintenance secret for /api/points/cron, /api/points/retry,
# and /api/points/health. Set this in Vercel production env.
CRON_SECRET=
# Optional alias for manual retry calls; CRON_SECRET is preferred for Vercel Cron.
POINTS_RETRY_SECRET=
